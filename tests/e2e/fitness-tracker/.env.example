MONGODB_URI=mongodb://admin:password@localhost:27017/fitness_tracker?authSource=admin
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# JWT Authentication (required for production)
JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json
JWT_ISSUER=https://your-tenant.auth0.com/
JWT_AUDIENCE=https://api.your-app.com

# Rate Limiting (requests per IP/user per minute)
RATE_LIMIT_IP_PER_MIN=100
RATE_LIMIT_USER_PER_MIN=1000
